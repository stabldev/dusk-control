---
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import features from "../data/features.json";
---

<Layout>
  <section
    class="min-h-dvh bg-[url(/hero-bg.webp)] bg-no-repeat bg-cover relative flex flex-col"
  >
    <div class="absolute bg-black/50 inset-0"></div>
    <header class="p-4 flex items-center justify-between relative">
      <div class="flex items-center gap-3">
        <img src="/favicon.ico" class="size-8" />
        <span class="font-bold text-white leading-none"
          >DUSK<br /><span class="opacity-50">CONTROL</span></span
        >
      </div>
      <a
        href="https://github.com/stabldev/dusk-control"
        target="_blank"
        class="text-white flex items-center gap-3"
        >GitHub
        <Icon name="github" class="size-6" />
      </a>
    </header>
    <div class="max-w-[1000px] m-auto flex gap-30 relative">
      <div class="flex flex-col gap-5">
        <h1 class="text-5xl font-black">Beyond Brightness.</h1>
        <h2 class="text-xl font-semibold opacity-65">
          Control your monitor's hardware brightness and dim your screen below
          its minimum.
        </h2>
        <p class="opacity-65">
          Dusk Control combines DDC/CI brightness control with intelligent
          software dimming to give you a seamless brightness experience for
          every display. Lightweight, native, and designed for Windows.
        </p>
        <div class="flex flex-col gap-2 mt-2">
          <a
            href="https://github.com/stabldev/dusk-control"
            target="_blank"
            class="flex items-center gap-2 bg-primary border border-primary-border w-max p-2 px-4 rounded-lg no-underline"
          >
            <Icon name="windows" class="size-5" />
            Download Dusk Control (v1.0.1)
          </a>
          <a
            href="https://get.microsoft.com/installer/download?referrer=appbadge"
            target="_self"
            class="w-max"
          >
            <img
              src="https://get.microsoft.com/images/en-us%20dark.svg"
              width="200"
            />
          </a>
        </div>
      </div>
      <img
        src="/screenshot.webp"
        class="rounded-xl border-2 border-b-4 border-primary-border h-max"
      />
    </div>
  </section>
  <section
    class="max-w-[1000px] mx-auto flex flex-col items-center gap-5 mt-20"
  >
    <h2 class="font-bold text-3xl">Features</h2>
    <p class="text-lg opacity-65 max-w-xl text-center">
      Dusk Control offers a variety of options and features to match your
      preferences. All of which are 100% free.
    </p>
    <div class="grid grid-cols-3 w-full mt-10 rounded-xl overflow-hidden gap-1">
      {
        features.map((f) => (
          <div class="flex flex-col gap-2 bg-secondary/50 p-4">
            <span class="size-10 bg-primary rounded-lg grid place-items-center">
              <Icon name={f.icon} class="size-6" />
            </span>
            <h4 class="font-bold text-lg mt-1">{f.title}</h4>
            <p class="opacity-65 text-sm">{f.description}</p>
          </div>
        ))
      }
    </div>
  </section>
  <section
    class="flex flex-col mt-20 items-center gap-5 bg-secondary/50 py-14 mx-2.5 rounded-xl"
  >
    <h2 class="font-bold text-3xl">Getting started</h2>
    <p class="text-lg opacity-65 max-w-xl text-center font-regular">
      Dusk Control is available for download from the Microsoft Store or as an
      installer from GitHub (recommended).
    </p>
    <div class="mt-5 flex gap-5">
      <div
        class="flex flex-col items-center bg-secondary/50 rounded-xl overflow-hidden border-2 border-b-4 border-primary-border w-80"
      >
        <div
          class="w-full bg-secondary/50 py-10 grid place-items-center border-b border-secondary-border/50"
        >
          <Icon name="windows" class="text-primary size-20" />
        </div>
        <div class="flex flex-col gap-1 items-center py-10">
          <span class="text-xl font-bold">Download</span>
          <a class="opacity-65 mt-1">Download installer (v1.0.1)</a>
          <a class="opacity-65">Get from the Microsoft Store</a>
          <a class="opacity-65">View all versions</a>
        </div>
      </div>
      <div
        class="flex flex-col items-center bg-secondary/50 rounded-xl overflow-hidden border-2 border-b-4 border-primary-border w-80"
      >
        <div
          class="w-full bg-secondary/50 py-10 grid place-items-center border-b border-secondary-border/50"
        >
          <Icon name="github" class="text-primary size-20" />
        </div>
        <div class="flex flex-col gap-1 items-center py-10">
          <span class="text-xl font-bold">GitHub</span>
          <a class="opacity-65 mt-1">Source code</a>
          <a class="opacity-65">Opened issues & Pull requests</a>
          <a class="opacity-65">Contributing.md</a>
        </div>
      </div>
    </div>
  </section>
  <footer class="flex items-center justify-between max-w-[1000px] mx-auto py-5">
    <span class="opacity-65 text-sm">
      Dusk Control © 2026 <a>Stabldev</a> · Photo by <a>Yogesh Pedamkar</a
      ></span
    >
    <span class="opacity-65 text-sm">gh-pages c-<a>3990b34</a></span>
  </footer>
</Layout>
